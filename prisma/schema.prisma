// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id            String   @id @default(cuid())
  shopifyDomain String   @unique
  plan          ShopPlan @default(FREE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns             Campaign[]
  analyticsEvents       AnalyticsEvent[]
  discountCodeGrants    DiscountCodeGrant[]
  uniqueDiscountCodes   UniqueDiscountCode[]
  discountCodePools     DiscountCodePool[]
  experiments           Experiment[]
  attributionTouches    AttributionTouch[]
  conversions           AttributionConversion[]
  emailTimers           EmailTimer[]
  advancedDiscountRules AdvancedDiscountRule[]
  advancedBadgeRules    AdvancedBadgeRule[]
  marketCampaignRules   MarketCampaignRule[]
  recommendations       CampaignRecommendation[]
  agencyShopAccesses    AgencyShopAccess[]
  onboardingChecklist   ShopOnboardingChecklist?
  settings              ShopSettings?
}

model ShopSettings {
  shopId                    String      @id
  defaultLocale             String      @default("en")
  enabledLocales            Json
  defaultTimezone           String      @default("UTC")
  defaultCurrency           String      @default("USD")
  enableDebugMode           Boolean     @default(false)
  brandName                 String?
  supportEmail              String?
  defaultCountry            String?
  customCartDrawerSelector  String?
  customCartPageSelector    String?
  customProductFormSelector String?
  analyticsEnabled          Boolean     @default(true)
  respectDoNotTrack         Boolean     @default(true)
  consentMode               ConsentMode @default(BASIC)
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopOnboardingChecklist {
  shopId                  String   @id
  firstCampaignCreated    Boolean  @default(false)
  appEmbedEnabled         Boolean  @default(false)
  productBlockAdded       Boolean  @default(false)
  cartBlockAdded          Boolean  @default(false)
  firstImpressionReceived Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Campaign {
  id        String         @id @default(cuid())
  shopId    String
  name      String
  status    CampaignStatus @default(DRAFT)
  type      CampaignType
  goal      CampaignGoal
  startsAt  DateTime?
  endsAt    DateTime?
  timezone  String         @default("UTC")
  priority  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  shop                   Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  placements             CampaignPlacement[]
  targeting              CampaignTargeting?
  design                 CampaignDesign?
  timerSettings          TimerSettings?
  freeShippingSettings   FreeShippingSettings?
  deliveryCutoffSettings DeliveryCutoffSettings?
  lowStockSettings       LowStockSettings?
  badgeSettings          BadgeSettings?
  discountSync           DiscountSync?
  discountCodeGrants     DiscountCodeGrant[]
  uniqueDiscountCodes    UniqueDiscountCode[]
  discountCodePools      DiscountCodePool[]
  experiments            Experiment[]
  experimentVariants     ExperimentVariant[]
  attributionTouches     AttributionTouch[]
  conversions            AttributionConversion[]
  emailTimers            EmailTimer[]
  advancedDiscountRules  AdvancedDiscountRule[]
  advancedBadgeRules     AdvancedBadgeRule[]
  marketCampaignRules    MarketCampaignRule[]
  recommendations        CampaignRecommendation[]
  translations           CampaignTranslation[]
  analyticsEvents        AnalyticsEvent[]

  @@index([shopId, status])
  @@index([shopId, type])
  @@index([shopId, priority])
  @@index([startsAt, endsAt])
}

model CampaignPlacement {
  id             String        @id @default(cuid())
  campaignId     String
  placementType  PlacementType
  customSelector String?
  enabled        Boolean       @default(true)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([placementType])
}

model CampaignTargeting {
  campaignId           String @id
  countries            Json
  markets              Json
  locales              Json
  productIds           Json
  collectionIds        Json
  productTags          Json
  customerTags         Json
  urlContains          Json
  utmSources           Json
  devices              Json
  excludeProductIds    Json
  excludeCollectionIds Json
  behaviorRules        Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignDesign {
  campaignId      String             @id
  templateKey     String             @default("clean-minimal")
  backgroundColor String             @default("#111827")
  textColor       String             @default("#FFFFFF")
  accentColor     String             @default("#22C55E")
  buttonColor     String             @default("#FFFFFF")
  buttonTextColor String             @default("#111827")
  fontSize        Int                @default(14)
  borderRadius    Int                @default(0)
  positionSticky  Boolean            @default(true)
  customCss       String?
  mobileEnabled   Boolean            @default(true)
  alignment       DesignAlignment    @default(CENTER)
  showCloseButton Boolean            @default(true)
  showIcon        Boolean            @default(true)
  icon            CampaignDesignIcon @default(NONE)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model TimerSettings {
  campaignId      String             @id
  mode            TimerMode
  durationMinutes Int?
  recurringDays   Json
  resetBehavior   TimerResetBehavior @default(NEVER)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model FreeShippingSettings {
  campaignId                String                    @id
  thresholdAmount           Decimal
  currencyCode              String
  includeDiscountedSubtotal Boolean                   @default(true)
  emptyCartMessage          String?
  successMessage            String?
  progressStyle             FreeShippingProgressStyle @default(BAR)
  thresholdRules            Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DeliveryCutoffSettings {
  campaignId          String                      @id
  cutoffHour          Int
  cutoffMinute        Int                         @default(0)
  processingDays      Int                         @default(0)
  minDeliveryDays     Int
  maxDeliveryDays     Int
  workingDays         Json
  holidays            Json
  countryRules        Json
  afterCutoffBehavior DeliveryAfterCutoffBehavior @default(SHOW_NEXT_WINDOW)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model LowStockSettings {
  campaignId        String  @id
  threshold         Int
  showExactQuantity Boolean @default(false)
  fallbackMessage   String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model BadgeSettings {
  campaignId    String        @id
  badgeText     String
  badgeShape    BadgeShape    @default(PILL)
  badgePosition BadgePosition @default(TOP_RIGHT)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DiscountSync {
  campaignId               String                 @id
  shopifyDiscountId        String?
  discountCode             String?
  method                   DiscountSyncMethod
  syncStartEnd             Boolean                @default(true)
  lastSyncedAt             DateTime?
  title                    String?
  valueType                DiscountCodeValueType?
  value                    Decimal?
  minimumSubtotal          Decimal?
  appliesOncePerCustomer   Boolean                @default(false)
  uniqueCodePrefix         String?
  uniqueCodeExpiresMinutes Int?
  uniqueCodeAutoApply      Boolean                @default(false)
  uniqueCodeStartsAt       DateTime?
  uniqueCodeEndsAt         DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopifyDiscountId])
  @@index([discountCode])
}

model DiscountCodeGrant {
  id                String                  @id @default(cuid())
  shopId            String
  campaignId        String
  visitorKey        String
  cartToken         String?
  code              String
  shopifyDiscountId String?
  status            DiscountCodeGrantStatus @default(ISSUED)
  expiresAt         DateTime?
  claimedAt         DateTime?
  appliedAt         DateTime?
  revokedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([shopId, code])
  @@index([campaignId, visitorKey])
  @@index([campaignId, status, expiresAt])
  @@index([shopId, createdAt])
}

model CampaignTranslation {
  id                       String  @id @default(cuid())
  campaignId               String
  locale                   String
  headline                 String?
  subheadline              String?
  ctaText                  String?
  ctaUrl                   String?
  expiredText              String?
  freeShippingEmptyText    String?
  freeShippingProgressText String?
  freeShippingSuccessText  String?
  deliveryBeforeCutoffText String?
  deliveryAfterCutoffText  String?
  lowStockText             String?
  badgeText                String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locale])
  @@index([locale])
}

model AnalyticsEvent {
  id            String             @id @default(cuid())
  shopId        String
  campaignId    String?
  eventType     AnalyticsEventType
  placementType PlacementType?
  sessionId     String?
  cartToken     String?
  orderId       String?
  revenueAmount Decimal?
  currencyCode  String?
  country       String?
  locale        String?
  path          String?
  userAgent     String?
  occurredAt    DateTime           @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([shopId, occurredAt])
  @@index([campaignId, eventType, occurredAt])
  @@index([eventType, occurredAt])
  @@index([orderId])
  @@index([sessionId])
}

model UniqueDiscountCode {
  id                String                   @id @default(cuid())
  shopId            String
  campaignId        String
  visitorId         String?
  sessionId         String?
  code              String
  shopifyDiscountId String?
  status            UniqueDiscountCodeStatus @default(AVAILABLE)
  assignedAt        DateTime?
  expiresAt         DateTime?
  usedAt            DateTime?
  orderId           String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([shopId, code])
  @@index([campaignId, status])
  @@index([campaignId, visitorId])
  @@index([sessionId])
  @@index([orderId])
  @@index([expiresAt])
}

model DiscountCodePool {
  id             String                 @id @default(cuid())
  shopId         String
  campaignId     String
  prefix         String
  discountType   DiscountCodeValueType
  value          Decimal?
  startsAt       DateTime?
  expiresAt      DateTime?
  totalGenerated Int                    @default(0)
  totalAssigned  Int                    @default(0)
  totalUsed      Int                    @default(0)
  status         DiscountCodePoolStatus @default(DRAFT)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([prefix])
}

model Experiment {
  id                            String                  @id @default(cuid())
  shopId                        String
  campaignId                    String
  name                          String
  status                        ExperimentStatus        @default(DRAFT)
  trafficSplitStrategy          String                  @default("WEIGHTED")
  primaryMetric                 ExperimentPrimaryMetric
  startsAt                      DateTime?
  endsAt                        DateTime?
  winnerVariantId               String?
  winnerDeclaredAt              DateTime?
  autoWinnerEnabled             Boolean                 @default(false)
  autoWinnerMinSampleSize       Int                     @default(100)
  autoWinnerMinRuntimeHours     Int                     @default(24)
  autoWinnerConfidenceThreshold Float                   @default(0.95)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt

  shop        Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variants    ExperimentVariant[]
  touches     AttributionTouch[]
  conversions AttributionConversion[]

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([winnerVariantId])
}

model ExperimentVariant {
  id                String                  @id @default(cuid())
  experimentId      String
  campaignId        String
  name              String
  weight            Int                     @default(0)
  status            ExperimentVariantStatus @default(DRAFT)
  designOverride    Json?
  textOverride      Json?
  discountOverride  Json?
  placementOverride Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  experiment  Experiment              @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  touches     AttributionTouch[]
  conversions AttributionConversion[]

  @@index([experimentId, status])
  @@index([campaignId])
}

model AttributionTouch {
  id            String             @id @default(cuid())
  shopId        String
  campaignId    String
  experimentId  String?
  variantId     String?
  visitorId     String?
  sessionId     String?
  eventType     AnalyticsEventType
  placementType PlacementType?
  path          String?
  country       String?
  locale        String?
  occurredAt    DateTime           @default(now())

  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign   Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  experiment Experiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variant    ExperimentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, occurredAt])
  @@index([campaignId, occurredAt])
  @@index([experimentId, variantId])
  @@index([visitorId])
  @@index([sessionId])
}

model AttributionConversion {
  id               String           @id @default(cuid())
  shopId           String
  campaignId       String
  experimentId     String?
  variantId        String?
  visitorId        String?
  sessionId        String?
  orderId          String
  revenueAmount    Decimal?
  currencyCode     String?
  attributionModel AttributionModel
  occurredAt       DateTime         @default(now())

  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign   Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  experiment Experiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variant    ExperimentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, occurredAt])
  @@index([campaignId, occurredAt])
  @@index([experimentId, variantId])
  @@index([orderId])
  @@index([visitorId])
}

model EmailTimer {
  id              String                    @id @default(cuid())
  shopId          String
  campaignId      String
  publicToken     String                    @unique
  mode            EmailTimerMode
  startsAt        DateTime?
  endsAt          DateTime?
  timezone        String                    @default("UTC")
  expiredBehavior EmailTimerExpiredBehavior @default(SHOW_EXPIRED)
  design          Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([campaignId])
  @@index([endsAt])
}

model AdvancedDiscountRule {
  id                    String                     @id @default(cuid())
  shopId                String
  campaignId            String?
  title                 String
  ruleType              AdvancedDiscountRuleType
  thresholds            Json?
  productIds            Json?
  collectionIds         Json?
  discountValue         Decimal?
  shippingDiscountValue Decimal?
  status                AdvancedDiscountRuleStatus @default(DRAFT)
  functionId            String?
  shopifyDiscountId     String?
  startsAt              DateTime?
  endsAt                DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([shopifyDiscountId])
}

model AdvancedBadgeRule {
  id         String           @id @default(cuid())
  shopId     String
  campaignId String
  priority   Int              @default(0)
  conditions Json
  design     Json
  status     Stage2RuleStatus @default(DRAFT)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, priority])
}

model MarketCampaignRule {
  id               String   @id @default(cuid())
  shopId           String
  campaignId       String
  enabled          Boolean  @default(true)
  marketId         String?
  countryCode      String?
  locale           String?
  currencyCode     String?
  thresholdAmount  Decimal?
  deliverySettings Json?
  textOverrides    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([campaignId])
  @@index([marketId])
  @@index([countryCode, locale])
}

model CampaignRecommendation {
  id          String                       @id @default(cuid())
  shopId      String
  campaignId  String?
  type        CampaignRecommendationType
  title       String
  description String
  impact      String?
  confidence  Float                        @default(0)
  status      CampaignRecommendationStatus @default(NEW)
  payload     Json?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([type])
}

model CampaignTemplate {
  id              String                   @id @default(cuid())
  key             String                   @unique
  category        CampaignTemplateCategory
  countryCode     String?
  locale          String                   @default("en")
  eventName       String
  goal            CampaignGoal
  type            CampaignType
  defaultTexts    Json
  defaultDesign   Json
  defaultSettings Json
  isSystem        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([category])
  @@index([countryCode, locale])
  @@index([goal, type])
}

model AgencyAccount {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopAccesses AgencyShopAccess[]
}

model AgencyShopAccess {
  agencyId  String
  shopId    String
  role      AgencyShopRole
  createdAt DateTime       @default(now())

  agency AgencyAccount @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  shop   Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([agencyId, shopId])
  @@index([shopId])
  @@index([role])
}

enum ShopPlan {
  FREE
  STARTER
  GROWTH
  PRO
}

enum ConsentMode {
  BASIC
  STRICT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum CampaignType {
  COUNTDOWN_BAR
  PRODUCT_TIMER
  CART_TIMER
  FREE_SHIPPING_GOAL
  DELIVERY_CUTOFF
  LOW_STOCK
  PRODUCT_BADGE
}

enum CampaignGoal {
  FLASH_SALE
  FREE_SHIPPING
  CART_RESCUE
  SHIPPING_PROMISE
  LOW_STOCK_URGENCY
  DELIVERY_CUTOFF
  PRODUCT_BADGE
  ANNOUNCEMENT
  LAUNCH
  PREORDER
}

enum PlacementType {
  TOP_BAR
  BOTTOM_BAR
  PRODUCT_PAGE
  COLLECTION_CARD
  CART_PAGE
  CART_DRAWER
  THANK_YOU_PAGE
  ORDER_STATUS_PAGE
  PASSWORD_PAGE
  CUSTOM_SELECTOR
}

enum TimerMode {
  FIXED_DATE
  EVERGREEN_SESSION
  RECURRING_DAILY
  RECURRING_WEEKLY
}

enum TimerResetBehavior {
  NEVER
  ON_SESSION_END
  DAILY
  WEEKLY
}

enum FreeShippingProgressStyle {
  BAR
  COMPACT
  CIRCULAR
}

enum DeliveryAfterCutoffBehavior {
  SHOW_NEXT_WINDOW
  SHOW_AFTER_CUTOFF_MESSAGE
  HIDE
}

enum BadgeShape {
  PILL
  ROUNDED
  SQUARE
}

enum BadgePosition {
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
  INLINE
}

enum DiscountSyncMethod {
  CODE
  AUTOMATIC
  UNIQUE_CODE
}

enum DiscountCodeValueType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum DiscountCodeGrantStatus {
  ISSUED
  REDEEMED
  EXPIRED
  REVOKED
}

enum UniqueDiscountCodeStatus {
  AVAILABLE
  ASSIGNED
  USED
  EXPIRED
  REVOKED
}

enum DiscountCodePoolStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXHAUSTED
  EXPIRED
  ARCHIVED
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum ExperimentVariantStatus {
  DRAFT
  ACTIVE
  PAUSED
  WINNER
  LOSER
  ARCHIVED
}

enum ExperimentPrimaryMetric {
  CLICK_RATE
  ADD_TO_CART_RATE
  CHECKOUT_RATE
  REVENUE_PER_VISITOR
}

enum AttributionModel {
  LAST_CLICK
  FIRST_CLICK
  LINEAR
  POSITION_BASED
  TIME_DECAY
  LAST_TOUCH_24H
  LAST_TOUCH_7D
  FIRST_TOUCH_7D
}

enum EmailTimerMode {
  FIXED_DATE
  EVERGREEN
}

enum EmailTimerExpiredBehavior {
  SHOW_EXPIRED
  SHOW_ZERO
  HIDE
}

enum Stage2RuleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AdvancedDiscountRuleType {
  SPEND_X_GET_Y
  TIERED_DISCOUNT
  FREE_GIFT
  PRODUCT_SHIPPING_COMBO
  CART_CONTENTS
}

enum AdvancedDiscountRuleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CampaignRecommendationType {
  CAMPAIGN_TEMPLATE
  PLACEMENT
  DISCOUNT_VALUE
  MESSAGE
  TARGETING
  TIMING
  MARKET_LOCALIZATION
}

enum CampaignRecommendationStatus {
  NEW
  VIEWED
  APPLIED
  DISMISSED
}

enum CampaignTemplateCategory {
  HOLIDAY
  SEASONAL
  COUNTRY_EVENT
  FLASH_SALE
  FREE_SHIPPING
  PRODUCT_LAUNCH
  CART_RECOVERY
  BFCM
}

enum AgencyShopRole {
  OWNER
  ADMIN
  ANALYST
}

enum AnalyticsEventType {
  IMPRESSION
  CLICK
  PRODUCT_VIEWED
  BADGE_IMPRESSION
  BADGE_CLICK
  COPY_CODE
  UNIQUE_CODE_ASSIGNED
  APPLY_CODE_CLICKED
  ADD_TO_CART
  CHECKOUT_STARTED
  POST_PURCHASE_IMPRESSION
  REORDER_OFFER_CLICK
  ORDER_ATTRIBUTED
}

enum DesignAlignment {
  LEFT
  CENTER
  RIGHT
}

enum CampaignDesignIcon {
  FIRE
  CLOCK
  TRUCK
  GIFT
  TAG
  NONE
}

{% if product %}
  {% assign pp_badge_metafield_value = blank %}
  {% if block.settings.metafieldNamespace != blank and block.settings.metafieldKey != blank %}
    {% assign pp_badge_metafield = product.metafields[block.settings.metafieldNamespace][block.settings.metafieldKey] %}
    {% assign pp_badge_metafield_value = pp_badge_metafield.value | default: pp_badge_metafield %}
  {% endif %}
  <div
    class="pp-root pp-product-badge"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-locale="{{ request.locale.iso_code | default: 'en' | escape }}"
    data-country="{{ localization.country.iso_code | default: '' | escape }}"
    data-market="{{ localization.market.handle | default: localization.market.id | default: '' | escape }}"
    data-product-id="gid://shopify/Product/{{ product.id }}"
    data-product-tags="{{ product.tags | join: ',' | escape }}"
    data-product-vendor="{{ product.vendor | escape }}"
    data-collection-ids="{% for collection in product.collections %}gid://shopify/Collection/{{ collection.id }}{% unless forloop.last %},{% endunless %}{% endfor %}"
    data-selected-variant-id="gid://shopify/ProductVariant/{{ product.selected_or_first_available_variant.id }}"
    data-inventory-quantity="{{ product.selected_or_first_available_variant.inventory_quantity | default: '' }}"
    data-price="{{ product.selected_or_first_available_variant.price | default: product.price | divided_by: 100.0 }}"
    data-compare-at-price="{{ product.selected_or_first_available_variant.compare_at_price | default: product.compare_at_price_max | divided_by: 100.0 }}"
    data-discount-active="{% if product.compare_at_price_max > product.price %}true{% else %}false{% endif %}"
    data-metafields="{% if pp_badge_metafield_value != blank %}{&quot;{{ block.settings.metafieldNamespace | escape }}.{{ block.settings.metafieldKey | escape }}&quot;:&quot;{{ pp_badge_metafield_value | escape }}&quot;}{% endif %}"
    data-campaign-id="{{ block.settings.campaignId | escape }}"
    data-fallback-mode="{{ block.settings.fallbackMode | escape }}"
    data-placement="{{ block.settings.placement | escape }}"
    data-api-base-url="{{ block.settings.apiBaseUrl | escape }}"
    data-debug="{{ block.settings.debugMode }}"
    data-debug-block="Promo Pulse badge"
    {{ block.shopify_attributes }}
  ></div>
{% endif %}
{{ 'campaign-surface.css' | asset_url | stylesheet_tag }}
<script src="{{ 'campaign-surface.js' | asset_url }}" defer></script>
<script src="{{ 'discount-code.js' | asset_url }}" defer></script>
<script src="{{ 'product-badge.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Promo Pulse badge",
  "target": "section",
  "stylesheet": "promo-pulse.css",
  "templates": ["product", "collection"],
  "settings": [
    {
      "type": "text",
      "id": "campaignId",
      "label": "Campaign ID"
    },
    {
      "type": "select",
      "id": "fallbackMode",
      "label": "Campaign selection",
      "default": "AUTO_ELIGIBLE",
      "options": [
        {
          "value": "AUTO_ELIGIBLE",
          "label": "Auto eligible"
        },
        {
          "value": "SPECIFIC_CAMPAIGN",
          "label": "Specific campaign"
        }
      ]
    },
    {
      "type": "select",
      "id": "placement",
      "label": "Campaign placement",
      "default": "COLLECTION_CARD",
      "options": [
        {
          "value": "COLLECTION_CARD",
          "label": "Collection card badge"
        },
        {
          "value": "PRODUCT_PAGE_BADGE",
          "label": "Product page badge"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "debugMode",
      "label": "Debug mode",
      "default": false
    },
    {
      "type": "text",
      "id": "metafieldNamespace",
      "label": "Metafield namespace for rules",
      "info": "Optional. Used only to expose one product metafield to advanced badge rules."
    },
    {
      "type": "text",
      "id": "metafieldKey",
      "label": "Metafield key for rules",
      "info": "Optional. Pair with namespace to expose namespace.key to the badge rule engine."
    },
    {
      "type": "text",
      "id": "apiBaseUrl",
      "label": "App backend URL for development",
      "info": "Optional. Use the Shopify CLI tunnel URL if the app proxy returns 404 in development."
    }
  ]
}
{% endschema %}

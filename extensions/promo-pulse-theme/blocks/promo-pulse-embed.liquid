{% if block.settings.enabled %}
  <div
    id="promo-pulse-app-embed"
    class="pp-root pp-embed"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-default-locale="{{ block.settings.defaultLocale | escape }}"
    data-locale="{{ request.locale.iso_code | default: block.settings.defaultLocale | escape }}"
    data-country="{{ localization.country.iso_code | default: '' | escape }}"
    data-cart-total-cents="{{ cart.total_price | default: 0 }}"
    data-cart-currency="{{ cart.currency.iso_code | default: shop.currency | escape }}"
    data-cart-token="{{ cart.token | default: '' | escape }}"
    data-product-id="{% if product %}gid://shopify/Product/{{ product.id }}{% endif %}"
    data-product-tags="{% if product %}{{ product.tags | join: ',' | escape }}{% endif %}"
    data-selected-variant-id="{% if product %}gid://shopify/ProductVariant/{{ product.selected_or_first_available_variant.id }}{% endif %}"
    data-inventory-quantity="{% if product %}{{ product.selected_or_first_available_variant.inventory_quantity | default: '' }}{% endif %}"
    data-collection-ids="{% if product %}{% for collection in product.collections %}gid://shopify/Collection/{{ collection.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}"
    data-cart-timer-src="{{ 'cart-timer.js' | asset_url }}"
    data-api-base-url="{{ block.settings.apiBaseUrl | escape }}"
    data-analytics-path="/apps/promo-pulse"
    data-debug="{{ block.settings.debugMode }}"
    data-debug-block="Promo Pulse embed"
    {{ block.shopify_attributes }}
  ></div>
  <script>
    window.PromoPulseCartSubtotal = {{ cart.total_price | default: 0 | divided_by: 100.0 }};
    window.PromoPulseCartCurrency = "{{ cart.currency.iso_code | default: shop.currency | escape }}";
    window.PromoPulseApiBaseUrl = "{{ block.settings.apiBaseUrl | escape }}";
  </script>
  {% assign promo_pulse_inline_config = app.metafields.promo_pulse.storefront_payload.value %}
  <script>
    window.PromoPulseCampaignConfigs = {% if promo_pulse_inline_config != blank %}{{ promo_pulse_inline_config | json }}{% else %}{"__promoPulseBundle":true,"__promoPulseSchemaVersion":2,"__promoPulseRequiresRuntimeFetch":true,"context":{"shop":{{ shop.permanent_domain | json }}},"campaigns":[]}{% endif %};
  </script>
  {{ 'campaign-surface-critical.css' | asset_url | stylesheet_tag }}
  <link
    rel="stylesheet"
    href="{{ 'campaign-surface.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>{{ 'campaign-surface.css' | asset_url | stylesheet_tag }}</noscript>
  <script src="{{ 'campaign-surface.js' | asset_url }}" defer></script>
  <script src="{{ 'campaign-loader.js' | asset_url }}" defer></script>
  <script src="{{ 'discount-code.js' | asset_url }}" defer></script>
  <script src="{{ 'promo-pulse.js' | asset_url }}" defer></script>
  <script src="{{ 'product-badge.js' | asset_url }}" defer></script>
  <script src="{{ 'free-shipping.js' | asset_url }}" defer></script>
  <script src="{{ 'delivery-cutoff.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-timer.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Promo Pulse embed",
  "target": "body",
  "stylesheet": "promo-pulse.css",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enabled",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "debugMode",
      "label": "Debug mode",
      "default": false
    },
    {
      "type": "select",
      "id": "defaultLocale",
      "label": "Default locale",
      "default": "en",
      "options": [
        {
          "value": "en",
          "label": "English"
        },
        {
          "value": "es",
          "label": "Spanish"
        },
        {
          "value": "pt-BR",
          "label": "Portuguese BR"
        },
        {
          "value": "fr",
          "label": "French"
        },
        {
          "value": "de",
          "label": "German"
        }
      ]
    },
    {
      "type": "text",
      "id": "apiBaseUrl",
      "label": "App backend URL for development",
      "info": "Optional. Use the Shopify CLI tunnel URL, for example https://example.trycloudflare.com, only if the app proxy returns 404 in development."
    }
  ]
}
{% endschema %}

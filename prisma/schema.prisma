// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id            String   @id @default(cuid())
  shopifyDomain String   @unique
  plan          ShopPlan @default(FREE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns                     Campaign[]
  analyticsEvents               AnalyticsEvent[]
  discountCodeGrants            DiscountCodeGrant[]
  uniqueDiscountCodes           UniqueDiscountCode[]
  uniqueDiscountCodeAssignments UniqueDiscountCodeAssignment[]
  discountCodePools             DiscountCodePool[]
  experiments                   Experiment[]
  attributionTouches            AttributionTouch[]
  conversions                   AttributionConversion[]
  emailTimers                   EmailTimer[]
  advancedDiscountRules         AdvancedDiscountRule[]
  advancedBadgeRules            AdvancedBadgeRule[]
  marketCampaignRules           MarketCampaignRule[]
  recommendations               CampaignRecommendation[]
  campaignTemplates             CampaignTemplate[]
  agencyShopAccesses            AgencyShopAccess[]
  contactRequests               ContactRequest[]
  onboardingChecklist           ShopOnboardingChecklist?
  settings                      ShopSettings?
}

model ShopSettings {
  shopId                         String      @id
  defaultLocale                  String      @default("en")
  enabledLocales                 Json
  defaultTimezone                String      @default("UTC")
  defaultCurrency                String      @default("USD")
  enableDebugMode                Boolean     @default(false)
  brandName                      String?
  supportEmail                   String?
  defaultCountry                 String?
  customTopBarSelector           String?
  customBottomBarSelector        String?
  customProductPageSelector      String?
  customProductPageBadgeSelector String?
  customCollectionCardSelector   String?
  customCartDrawerSelector       String?
  customCartPageSelector         String?
  customProductFormSelector      String?
  customThankYouPageSelector     String?
  customOrderStatusPageSelector  String?
  customHtmlSlotSelector         String?
  separateMobileSelectors        Boolean     @default(false)
  mobileSelectors                Json?
  analyticsEnabled               Boolean     @default(true)
  respectDoNotTrack              Boolean     @default(true)
  consentMode                    ConsentMode @default(BASIC)
  createdAt                      DateTime    @default(now())
  updatedAt                      DateTime    @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopOnboardingChecklist {
  shopId                  String   @id
  firstCampaignCreated    Boolean  @default(false)
  appEmbedEnabled         Boolean  @default(false)
  productBlockAdded       Boolean  @default(false)
  cartBlockAdded          Boolean  @default(false)
  firstImpressionReceived Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Campaign {
  id                String         @id @default(cuid())
  shopId            String
  name              String
  status            CampaignStatus @default(DRAFT)
  type              CampaignType
  goal              CampaignGoal
  startsAt          DateTime?
  endsAt            DateTime?
  timezone          String         @default("UTC")
  priority          Int            @default(0)
  lastSavedAt       DateTime       @default(now())
  publishedAt       DateTime?
  publishedSnapshot Json?
  assetsRequested   Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  shop                          Shop                           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  placements                    CampaignPlacement[]
  targeting                     CampaignTargeting?
  design                        CampaignDesign?
  timerSettings                 TimerSettings?
  cartRescueSettings            CartRescueSettings?
  freeShippingSettings          FreeShippingSettings?
  deliveryCutoffSettings        DeliveryCutoffSettings?
  lowStockSettings              LowStockSettings?
  badgeSettings                 BadgeSettings?
  discountSync                  DiscountSync?
  discountCodeGrants            DiscountCodeGrant[]
  uniqueDiscountCodes           UniqueDiscountCode[]
  uniqueDiscountCodeAssignments UniqueDiscountCodeAssignment[]
  discountCodePools             DiscountCodePool[]
  experiments                   Experiment[]
  experimentVariants            ExperimentVariant[]
  attributionTouches            AttributionTouch[]
  conversions                   AttributionConversion[]
  emailTimers                   EmailTimer[]
  advancedDiscountRules         AdvancedDiscountRule[]
  advancedBadgeRules            AdvancedBadgeRule[]
  marketCampaignRules           MarketCampaignRule[]
  recommendations               CampaignRecommendation[]
  translations                  CampaignTranslation[]
  analyticsEvents               AnalyticsEvent[]
  assets                        CampaignAsset[]

  @@index([shopId, status])
  @@index([shopId, type])
  @@index([shopId, priority])
  @@index([shopId, publishedAt])
  @@index([startsAt, endsAt])
}

enum CampaignAssetSource {
  GENERATED
  EXTRACTED
  SVG
}

// A visual asset the AI generated/extracted for a campaign and uploaded to the
// Shopify Files library. The Shopify URL is the only storage — there is no
// server-side fallback.
model CampaignAsset {
  id            String              @id @default(cuid())
  campaignId    String
  shopifyFileId String
  shopifyUrl    String
  assetType     String
  source        CampaignAssetSource
  modelUsed     String?
  promptUsed    String?
  createdAt     DateTime            @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignPlacement {
  id             String        @id @default(cuid())
  campaignId     String
  placementType  PlacementType
  customSelector String?
  customStyle    String?
  enabled        Boolean       @default(true)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([placementType])
}

model CampaignTargeting {
  campaignId           String @id
  countries            Json
  markets              Json
  locales              Json
  productIds           Json
  collectionIds        Json
  productTags          Json
  customerTags         Json
  urlContains          Json
  excludedUrlContains  Json   @default("[]")
  utmSources           Json
  devices              Json
  excludeProductIds    Json
  excludeCollectionIds Json
  behaviorRules        Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignDesign {
  campaignId               String                   @id
  templateKey              String                   @default("clean-minimal")
  layout                   DesignLayout             @default(STANDARD)
  backgroundType           DesignBackgroundType     @default(SOLID)
  backgroundColor          String                   @default("#111827")
  backgroundImageUrl       String                   @default("")
  gradientStartColor       String                   @default("#252237")
  gradientEndColor         String                   @default("#4C4861")
  gradientAngle            Int                      @default(90)
  textColor                String                   @default("#FFFFFF")
  accentColor              String                   @default("#22C55E")
  buttonColor              String                   @default("#FFFFFF")
  buttonTextColor          String                   @default("#111827")
  closeButtonColor         String                   @default("#111827")
  fontSize                 Int                      @default(14)
  borderRadius             Int                      @default(0)
  borderSize               Int                      @default(0)
  borderColor              String                   @default("#E5E7EB")
  fontFamily               DesignFontFamily         @default(THEME)
  titleFontSize            Int                      @default(22)
  titleColor               String                   @default("#FFFFFF")
  subheadingFontSize       Int                      @default(14)
  subheadingColor          String                   @default("#D1D5DB")
  timerFontSize            Int                      @default(38)
  timerColor               String                   @default("#FFFFFF")
  legendFontSize           Int                      @default(12)
  legendColor              String                   @default("#D1D5DB")
  timerNumberFontSize      Int                      @default(38)
  timerLabelFontSize       Int                      @default(12)
  timerGap                 Int                      @default(10)
  timerUnitGap             Int                      @default(3)
  timerPaddingBlock        Int                      @default(8)
  timerPaddingInline       Int                      @default(12)
  timerStyle               DesignTimerStyle         @default(PLAIN)
  timerFormat              DesignTimerFormat        @default(UNITS)
  timerNumberLayout        DesignTimerNumberLayout  @default(INLINE)
  timerShowLabels          Boolean                  @default(true)
  timerShowSeconds         Boolean                  @default(true)
  timerDaysLabel           String                   @default("Days")
  timerHoursLabel          String                   @default("Hrs")
  timerMinutesLabel        String                   @default("Mins")
  timerSecondsLabel        String                   @default("Secs")
  timerHideZeroDays        Boolean                  @default(true)
  timerSurfaceColor        String                   @default("#FFFFFF")
  timerSurfaceBorderColor  String                   @default("#D1D5DB")
  timerSurfaceBorderSize   Int                      @default(0)
  timerSurfaceRadius       Int                      @default(8)
  paddingBlock             Int                      @default(20)
  paddingInline            Int                      @default(24)
  marginTop                Int                      @default(0)
  marginBottom             Int                      @default(0)
  marginLeft               Int                      @default(0)
  marginRight              Int                      @default(0)
  contentGap               Int                      @default(8)
  contentMaxWidth          Int                      @default(960)
  fullWidth                Boolean                  @default(false)
  positionMode             DesignPositionMode       @default(FLOW)
  positionSticky           Boolean                  @default(true)
  floatPosition            DesignFloatPosition      @default(FIXED)
  floatOffsetTop           String                   @default("0")
  floatOffsetBottom        String                   @default("auto")
  floatOffsetLeft          String                   @default("0")
  floatOffsetRight         String                   @default("0")
  entranceAnimation        DesignBannerAnimation    @default(FADE)
  exitAnimation            DesignBannerAnimation    @default(FADE)
  animationDurationMs      Int                      @default(220)
  timerTickAnimation       DesignTimerTickAnimation @default(NONE)
  timerTickDurationMs      Int                      @default(220)
  customCss                String?
  mobileEnabled            Boolean                  @default(true)
  alignment                DesignAlignment          @default(CENTER)
  showCloseButton          Boolean                  @default(true)
  closeButtonSize          Int                      @default(20)
  dismissBehavior          DesignDismissBehavior    @default(SHOW_AGAIN)
  showButton               Boolean                  @default(true)
  showProgressBar          Boolean                  @default(true)
  progressTarget           String                   @default("FREE_SHIPPING")
  progressBarStyle         String                   @default("BAR")
  progressSteps            Int                      @default(4)
  progressHeight           Int                      @default(8)
  progressRadius           Int                      @default(999)
  progressTrackColor       String                   @default("#E5E7EB")
  progressFillColor        String                   @default("#22C55E")
  progressTextColor        String                   @default("#111827")
  progressEffect           String                   @default("NONE")
  progressShowLabel        Boolean                  @default(false)
  showIcon                 Boolean                  @default(true)
  icon                     CampaignDesignIcon       @default(NONE)
  iconSize                 Int                      @default(20)
  customIconUrl            String                   @default("")
  showDiscountCode         Boolean                  @default(true)
  showCopyCodeButton       Boolean                  @default(true)
  showApplyDiscountButton  Boolean                  @default(true)
  offerCodeLayout          DesignOfferCodeLayout    @default(INLINE)
  offerCodeLabel           String                   @default("Discount code")
  copyCodeLabel            String                   @default("Copy code")
  copiedCodeLabel          String                   @default("Copied")
  applyDiscountLabel       String                   @default("Apply discount")
  appliedDiscountMessage   String                   @default("Discount applied successfully.")
  offerCodeTextColor       String                   @default("#111827")
  offerCodeBackgroundColor String                   @default("#FFFFFF")
  offerCodeBorderColor     String                   @default("#D1D5DB")
  offerCodeFontSize        Int                      @default(13)
  offerCodeBorderRadius    Int                      @default(4)
  offerCodePaddingBlock    Int                      @default(5)
  offerCodePaddingInline   Int                      @default(8)
  offerCodeGap             Int                      @default(6)
  offerCopyBehavior        DesignOfferCopyBehavior  @default(FEEDBACK)
  offerApplyBehavior       DesignOfferApplyBehavior @default(SHOW_APPLIED)
  mobileDesign             Json?
  structureCompact         String?
  structureCss             String?
  structureMessages        String?
  structureVersion         Int                      @default(1)
  structureEdited          Boolean                  @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model TimerSettings {
  campaignId      String               @id
  mode            TimerMode
  durationMinutes Int?
  recurringDays   Json
  resetBehavior   TimerResetBehavior   @default(NEVER)
  expiredBehavior TimerExpiredBehavior @default(UNPUBLISH_TIMER)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CartRescueSettings {
  campaignId     String               @id
  rescueReason   CartRescueReason     @default(CART_RESERVED)
  showTimer      Boolean              @default(true)
  showButton     Boolean              @default(true)
  timerStart     CartRescueTimerStart @default(CART_VIEWED)
  armBeforeStart Boolean              @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model FreeShippingSettings {
  campaignId                String                    @id
  thresholdAmount           Decimal
  currencyCode              String
  includeDiscountedSubtotal Boolean                   @default(true)
  emptyCartMessage          String?
  successMessage            String?
  progressStyle             FreeShippingProgressStyle @default(BAR)
  thresholdRules            Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DeliveryCutoffSettings {
  campaignId          String                      @id
  cutoffHour          Int
  cutoffMinute        Int                         @default(0)
  processingDays      Int                         @default(0)
  minDeliveryDays     Int
  maxDeliveryDays     Int
  workingDays         Json
  holidays            Json
  countryRules        Json
  afterCutoffBehavior DeliveryAfterCutoffBehavior @default(SHOW_NEXT_WINDOW)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model LowStockSettings {
  campaignId        String  @id
  threshold         Int
  showExactQuantity Boolean @default(false)
  fallbackMessage   String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model BadgeSettings {
  campaignId    String        @id
  badgeText     String
  badgeShape    BadgeShape    @default(PILL)
  badgePosition BadgePosition @default(TOP_RIGHT)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DiscountSync {
  campaignId                String                 @id
  shopifyDiscountId         String?
  discountCode              String?
  method                    DiscountSyncMethod
  syncStartEnd              Boolean                @default(true)
  lastSyncedAt              DateTime?
  title                     String?
  valueType                 DiscountCodeValueType?
  value                     Decimal?
  minimumSubtotal           Decimal?
  appliesOncePerCustomer    Boolean                @default(false)
  showCodeOnStorefront      Boolean                @default(true)
  uniqueCodePrefix          String?
  uniqueCodeExpiresMinutes  Int?
  uniqueCodeAutoApply       Boolean                @default(false)
  uniqueCodeReassignExpired Boolean                @default(false)
  uniqueCodeStartsAt        DateTime?
  uniqueCodeEndsAt          DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopifyDiscountId])
  @@index([discountCode])
}

model DiscountCodeGrant {
  id                String                  @id @default(cuid())
  shopId            String
  campaignId        String
  visitorKey        String
  cartToken         String?
  code              String
  shopifyDiscountId String?
  status            DiscountCodeGrantStatus @default(ISSUED)
  expiresAt         DateTime?
  claimedAt         DateTime?
  appliedAt         DateTime?
  revokedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([shopId, code])
  @@index([campaignId, visitorKey])
  @@index([campaignId, status, expiresAt])
  @@index([shopId, createdAt])
}

model CampaignTranslation {
  id                       String  @id @default(cuid())
  campaignId               String
  locale                   String
  headline                 String?
  subheadline              String?
  ctaText                  String?
  ctaUrl                   String?
  expiredText              String?
  freeShippingEmptyText    String?
  freeShippingProgressText String?
  freeShippingSuccessText  String?
  deliveryBeforeCutoffText String?
  deliveryAfterCutoffText  String?
  lowStockText             String?
  badgeText                String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locale])
  @@index([locale])
}

model AnalyticsEvent {
  id            String             @id @default(cuid())
  shopId        String
  campaignId    String?
  eventType     AnalyticsEventType
  placementType PlacementType?
  sessionId     String?
  cartToken     String?
  orderId       String?
  revenueAmount Decimal?
  currencyCode  String?
  country       String?
  locale        String?
  path          String?
  userAgent     String?
  occurredAt    DateTime           @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([shopId, occurredAt])
  @@index([campaignId, eventType, occurredAt])
  @@index([eventType, occurredAt])
  @@index([orderId])
  @@index([sessionId])
}

model UniqueDiscountCode {
  id                String                   @id @default(cuid())
  shopId            String
  campaignId        String
  poolId            String?
  visitorId         String?
  sessionId         String?
  code              String
  shopifyDiscountId String?
  status            UniqueDiscountCodeStatus @default(AVAILABLE)
  assignedAt        DateTime?
  expiresAt         DateTime?
  usedAt            DateTime?
  orderId           String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  shop        Shop                           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign    Campaign                       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pool        DiscountCodePool?              @relation(fields: [poolId], references: [id], onDelete: SetNull)
  assignments UniqueDiscountCodeAssignment[]

  @@unique([shopId, code])
  @@index([campaignId, status])
  @@index([campaignId, visitorId])
  @@index([poolId, status])
  @@index([sessionId])
  @@index([orderId])
  @@index([expiresAt])
}

model UniqueDiscountCodeAssignment {
  id         String    @id @default(cuid())
  shopId     String
  campaignId String
  codeId     String
  visitorId  String
  sessionId  String?
  code       String
  assignedAt DateTime
  expiresAt  DateTime?
  expiredAt  DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign   Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  uniqueCode UniqueDiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([shopId, campaignId, visitorId])
  @@index([campaignId, expiresAt])
  @@index([campaignId, codeId])
  @@index([visitorId])
}

model DiscountCodePool {
  id                    String                 @id @default(cuid())
  shopId                String
  campaignId            String
  prefix                String
  discountType          DiscountCodeValueType
  value                 Decimal?
  startsAt              DateTime?
  expiresAt             DateTime?
  reassignExpiredUnused Boolean                @default(false)
  totalGenerated        Int                    @default(0)
  totalAssigned         Int                    @default(0)
  totalUsed             Int                    @default(0)
  status                DiscountCodePoolStatus @default(DRAFT)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  shop     Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  codes    UniqueDiscountCode[]

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([prefix])
}

model Experiment {
  id                            String                  @id @default(cuid())
  shopId                        String
  campaignId                    String
  name                          String
  status                        ExperimentStatus        @default(DRAFT)
  trafficSplitStrategy          String                  @default("WEIGHTED")
  primaryMetric                 ExperimentPrimaryMetric
  startsAt                      DateTime?
  endsAt                        DateTime?
  winnerVariantId               String?
  winnerDeclaredAt              DateTime?
  winnerAppliedAt               DateTime?
  autoWinnerEnabled             Boolean                 @default(false)
  autoWinnerMinSampleSize       Int                     @default(100)
  autoWinnerMinRuntimeHours     Int                     @default(24)
  autoWinnerConfidenceThreshold Float                   @default(0.95)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt

  shop        Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variants    ExperimentVariant[]
  touches     AttributionTouch[]
  conversions AttributionConversion[]

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([winnerVariantId])
}

model ExperimentVariant {
  id                String                  @id @default(cuid())
  experimentId      String
  campaignId        String
  name              String
  weight            Int                     @default(0)
  status            ExperimentVariantStatus @default(DRAFT)
  designOverride    Json?
  textOverride      Json?
  discountOverride  Json?
  placementOverride Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  experiment  Experiment              @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  touches     AttributionTouch[]
  conversions AttributionConversion[]

  @@index([experimentId, status])
  @@index([campaignId])
}

model AttributionTouch {
  id            String             @id @default(cuid())
  shopId        String
  campaignId    String
  experimentId  String?
  variantId     String?
  visitorId     String?
  sessionId     String?
  eventType     AnalyticsEventType
  placementType PlacementType?
  path          String?
  country       String?
  locale        String?
  occurredAt    DateTime           @default(now())

  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign   Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  experiment Experiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variant    ExperimentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, occurredAt])
  @@index([campaignId, occurredAt])
  @@index([experimentId, variantId])
  @@index([visitorId])
  @@index([sessionId])
}

model AttributionConversion {
  id               String           @id @default(cuid())
  shopId           String
  campaignId       String
  experimentId     String?
  variantId        String?
  visitorId        String?
  sessionId        String?
  orderId          String
  revenueAmount    Decimal?
  currencyCode     String?
  attributionModel AttributionModel
  occurredAt       DateTime         @default(now())

  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign   Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  experiment Experiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variant    ExperimentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, occurredAt])
  @@index([campaignId, occurredAt])
  @@index([experimentId, variantId])
  @@index([orderId])
  @@index([visitorId])
}

model EmailTimer {
  id              String                    @id @default(cuid())
  shopId          String
  campaignId      String
  publicToken     String                    @unique
  mode            EmailTimerMode
  startsAt        DateTime?
  endsAt          DateTime?
  timezone        String                    @default("UTC")
  expiredBehavior EmailTimerExpiredBehavior @default(SHOW_EXPIRED)
  design          Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([campaignId])
  @@index([endsAt])
}

model AdvancedDiscountRule {
  id                    String                     @id @default(cuid())
  shopId                String
  campaignId            String?
  title                 String
  ruleType              AdvancedDiscountRuleType
  thresholds            Json?
  productIds            Json?
  collectionIds         Json?
  discountValue         Decimal?
  shippingDiscountValue Decimal?
  status                AdvancedDiscountRuleStatus @default(DRAFT)
  functionId            String?
  shopifyDiscountId     String?
  startsAt              DateTime?
  endsAt                DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([shopifyDiscountId])
}

model AdvancedBadgeRule {
  id         String           @id @default(cuid())
  shopId     String
  campaignId String
  priority   Int              @default(0)
  conditions Json
  design     Json
  status     Stage2RuleStatus @default(DRAFT)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, priority])
}

model MarketCampaignRule {
  id               String   @id @default(cuid())
  shopId           String
  campaignId       String
  enabled          Boolean  @default(true)
  marketId         String?
  countryCode      String?
  locale           String?
  currencyCode     String?
  thresholdAmount  Decimal?
  deliverySettings Json?
  textOverrides    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([campaignId])
  @@index([marketId])
  @@index([countryCode, locale])
}

model CampaignRecommendation {
  id          String                       @id @default(cuid())
  shopId      String
  campaignId  String?
  type        CampaignRecommendationType
  title       String
  description String
  impact      String?
  confidence  Float                        @default(0)
  status      CampaignRecommendationStatus @default(NEW)
  payload     Json?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([campaignId, status])
  @@index([type])
}

model CampaignTemplate {
  id              String                   @id @default(cuid())
  shopId          String?
  key             String                   @unique
  category        CampaignTemplateCategory
  countryCode     String?
  locale          String                   @default("en")
  eventName       String
  goal            CampaignGoal
  type            CampaignType
  defaultTexts    Json
  defaultDesign   Json
  defaultSettings Json
  isSystem        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([isSystem, shopId])
  @@index([category])
  @@index([countryCode, locale])
  @@index([goal, type])
}

model AgencyAccount {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopAccesses AgencyShopAccess[]
}

model AgencyShopAccess {
  agencyId  String
  shopId    String
  role      AgencyShopRole
  createdAt DateTime       @default(now())

  agency AgencyAccount @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  shop   Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([agencyId, shopId])
  @@index([shopId])
  @@index([role])
}

model ContactRequest {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopDomain String
  type       String
  subject    String
  message    String
  email      String?
  createdAt  DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([shopDomain, createdAt])
  @@index([type])
}


{% if block.settings.enabled %}
  <div
    id="counterpulse-app-embed"
    class="pp-root pp-embed{% if block.settings.debugMode %} pp-root--debug{% endif %}"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-default-locale="{{ block.settings.defaultLocale | escape }}"
    data-locale="{{ request.locale.iso_code | default: block.settings.defaultLocale | escape }}"
    data-country="{{ localization.country.iso_code | default: '' | escape }}"
    data-cart-total-cents="{{ cart.total_price | default: 0 }}"
    data-cart-currency="{{ cart.currency.iso_code | default: shop.currency | escape }}"
    data-cart-token="{{ cart.token | default: '' | escape }}"
    data-product-id="{% if product %}gid://shopify/Product/{{ product.id }}{% endif %}"
    data-product-tags="{% if product %}{{ product.tags | join: ',' | escape }}{% endif %}"
    data-collection-ids="{% if product %}{% for collection in product.collections %}gid://shopify/Collection/{{ collection.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}"
    data-cart-timer-src="{{ 'cart-timer.js' | asset_url }}"
    data-api-base-url="{{ block.settings.apiBaseUrl | escape }}"
    data-analytics-path="/apps/counterpulse-campaigns"
    data-debug="{{ block.settings.debugMode }}"
    data-debug-block="Promo Pulse embed"
    {{ block.shopify_attributes }}
  >
    {% if block.settings.debugMode %}
      <aside class="pp-debug pp-debug--embed" role="status" aria-live="polite">
        <strong>Promo Pulse embed renderizado</strong>
        <p>
          Este App Embed carga las barras globales y el soporte automatico de cart drawer.
        </p>
        <dl>
          <dt>Bloque</dt>
          <dd>Promo Pulse embed</dd>
          <dt>Shop</dt>
          <dd>{{ shop.permanent_domain | escape }}</dd>
          <dt>Locale</dt>
          <dd>{{ request.locale.iso_code | default: block.settings.defaultLocale | escape }}</dd>
          <dt>Country</dt>
          <dd>{{ localization.country.iso_code | default: 'unknown' | escape }}</dd>
          <dt>Cart subtotal</dt>
          <dd>{{ cart.total_price | default: 0 | divided_by: 100.0 }} {{ cart.currency.iso_code | default: shop.currency | escape }}</dd>
          <dt>Placements automaticos</dt>
          <dd>TOP_BAR, BOTTOM_BAR, CUSTOM_SELECTOR, CART_DRAWER</dd>
          <dt>Product context</dt>
          <dd>{% if product %}gid://shopify/Product/{{ product.id }}{% else %}none{% endif %}</dd>
          <dt>API ejemplo</dt>
          <dd>
            <code data-pp-debug-url>/apps/counterpulse-campaigns?shop={{ shop.permanent_domain | escape }}&amp;placement=TOP_BAR&amp;locale={{ request.locale.iso_code | default: block.settings.defaultLocale | escape }}</code>
          </dd>
        </dl>
        <p class="pp-debug__status" data-pp-debug-status>
          Embed Liquid renderizado. Esperando que carguen los assets JavaScript.
        </p>
        <p class="pp-debug__hint">
          Si ves este panel y no aparece una barra, revisa que exista una campana ACTIVE con placement TOP_BAR, BOTTOM_BAR, CUSTOM_SELECTOR o CART_DRAWER y targeting compatible.
        </p>
      </aside>
    {% endif %}
  </div>
  <script>
    window.CounterPulseCartSubtotal = {{ cart.total_price | default: 0 | divided_by: 100.0 }};
    window.CounterPulseCartCurrency = "{{ cart.currency.iso_code | default: shop.currency | escape }}";
    window.CounterPulseApiBaseUrl = "{{ block.settings.apiBaseUrl | escape }}";
  </script>
  <script src="{{ 'discount-code.js' | asset_url }}" defer></script>
  <script src="{{ 'free-shipping.js' | asset_url }}" defer></script>
  <script src="{{ 'delivery-cutoff.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-timer.js' | asset_url }}" defer></script>
  <script src="{{ 'promo-pilot.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Promo Pulse embed",
  "target": "body",
  "stylesheet": "promo-pilot.css",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enabled",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "debugMode",
      "label": "Debug mode",
      "default": false
    },
    {
      "type": "select",
      "id": "defaultLocale",
      "label": "Default locale",
      "default": "en",
      "options": [
        {
          "value": "en",
          "label": "English"
        },
        {
          "value": "es",
          "label": "Spanish"
        },
        {
          "value": "pt-BR",
          "label": "Portuguese BR"
        },
        {
          "value": "fr",
          "label": "French"
        },
        {
          "value": "de",
          "label": "German"
        }
      ]
    },
    {
      "type": "text",
      "id": "apiBaseUrl",
      "label": "App backend URL for development",
      "info": "Optional. Use the Shopify CLI tunnel URL, for example https://example.trycloudflare.com, only if the app proxy returns 404 in development."
    }
  ]
}
{% endschema %}

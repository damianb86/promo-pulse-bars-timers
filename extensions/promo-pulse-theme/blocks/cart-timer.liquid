<div
  class="pp-root pp-cart-timer"
  data-shop="{{ shop.permanent_domain | escape }}"
  data-locale="{{ request.locale.iso_code | default: 'en' | escape }}"
  data-country="{{ localization.country.iso_code | default: '' | escape }}"
  data-cart-total-cents="{{ cart.total_price | default: 0 }}"
  data-cart-currency="{{ cart.currency.iso_code | default: shop.currency | escape }}"
  data-cart-token="{{ cart.token | default: '' | escape }}"
  data-campaign-id="{{ block.settings.campaignId | escape }}"
  data-fallback-mode="{{ block.settings.fallbackMode | escape }}"
  data-alignment="{{ block.settings.alignment | escape }}"
  data-compact="{{ block.settings.compactMode }}"
  data-api-base-url="{{ block.settings.apiBaseUrl | escape }}"
  data-debug="{{ block.settings.debugMode }}"
  data-debug-block="Promo Pulse cart promotion"
  {{ block.shopify_attributes }}
></div>
{{ 'campaign-surface.css' | asset_url | stylesheet_tag }}
<script src="{{ 'campaign-surface.js' | asset_url }}" defer></script>
<script src="{{ 'discount-code.js' | asset_url }}" defer></script>
<script src="{{ 'cart-timer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Promo Pulse cart promotion",
  "target": "section",
  "stylesheet": "promo-pulse.css",
  "templates": ["cart"],
  "settings": [
    {
      "type": "text",
      "id": "campaignId",
      "label": "Campaign ID"
    },
    {
      "type": "select",
      "id": "fallbackMode",
      "label": "Campaign selection",
      "default": "AUTO_ELIGIBLE",
      "options": [
        {
          "value": "AUTO_ELIGIBLE",
          "label": "Auto eligible"
        },
        {
          "value": "SPECIFIC_CAMPAIGN",
          "label": "Specific campaign"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "CENTER",
      "options": [
        {
          "value": "LEFT",
          "label": "Left"
        },
        {
          "value": "CENTER",
          "label": "Center"
        },
        {
          "value": "RIGHT",
          "label": "Right"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "compactMode",
      "label": "Compact mode",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "debugMode",
      "label": "Debug mode",
      "default": false
    },
    {
      "type": "text",
      "id": "apiBaseUrl",
      "label": "App backend URL for development",
      "info": "Optional. Use the Shopify CLI tunnel URL if the app proxy returns 404 in development."
    }
  ]
}
{% endschema %}

{% if product %}
  <div
    class="pp-root pp-product-timer{% if block.settings.debugMode %} pp-root--debug{% endif %}"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-locale="{{ request.locale.iso_code | default: 'en' | escape }}"
    data-country="{{ localization.country.iso_code | default: '' | escape }}"
    data-product-id="gid://shopify/Product/{{ product.id }}"
    data-product-tags="{{ product.tags | join: ',' | escape }}"
    data-selected-variant-id="{{ product.selected_or_first_available_variant.id }}"
    data-inventory-quantity="{{ product.selected_or_first_available_variant.inventory_quantity }}"
    data-variants-script-id="counterpulse-variants-{{ block.id }}"
    data-campaign-id="{{ block.settings.campaignId | escape }}"
    data-fallback-mode="{{ block.settings.fallbackMode | escape }}"
    data-alignment="{{ block.settings.alignment | escape }}"
    data-compact="{{ block.settings.compactMode }}"
    data-show-icon="{{ block.settings.showIcon }}"
    data-api-base-url="{{ block.settings.apiBaseUrl | escape }}"
    data-debug="{{ block.settings.debugMode }}"
    data-debug-block="Promo Pulse product timer"
    {{ block.shopify_attributes }}
  >
    {% if block.settings.debugMode %}
      <aside class="pp-debug" role="status" aria-live="polite">
        <strong>Promo Pulse product timer renderizado</strong>
        <p>
          Este bloque busca campanas elegibles para la pagina de producto.
        </p>
        <dl>
          <dt>Bloque</dt>
          <dd>Promo Pulse product timer</dd>
          <dt>Placement</dt>
          <dd>PRODUCT_PAGE</dd>
          <dt>Selection</dt>
          <dd>{{ block.settings.fallbackMode | escape }}</dd>
          <dt>Campaign ID</dt>
          <dd>{% if block.settings.campaignId != blank %}{{ block.settings.campaignId | escape }}{% else %}auto{% endif %}</dd>
          <dt>Product ID</dt>
          <dd>gid://shopify/Product/{{ product.id }}</dd>
          <dt>Variant ID</dt>
          <dd>{{ product.selected_or_first_available_variant.id }}</dd>
          <dt>Inventory</dt>
          <dd>{{ product.selected_or_first_available_variant.inventory_quantity | default: 'not exposed' }}</dd>
          <dt>Tags</dt>
          <dd>{% if product.tags.size > 0 %}{{ product.tags | join: ', ' | escape }}{% else %}none{% endif %}</dd>
          <dt>Locale</dt>
          <dd>{{ request.locale.iso_code | default: 'en' | escape }}</dd>
          <dt>Country</dt>
          <dd>{{ localization.country.iso_code | default: 'unknown' | escape }}</dd>
          <dt>API ejemplo</dt>
          <dd>
            <code data-pp-debug-url>/apps/counterpulse-campaigns?shop={{ shop.permanent_domain | escape }}&amp;placement=PRODUCT_PAGE&amp;productId=gid://shopify/Product/{{ product.id }}&amp;locale={{ request.locale.iso_code | default: 'en' | escape }}</code>
          </dd>
          <dt>Scripts</dt>
          <dd>product-timer.js, delivery-cutoff.js, low-stock.js</dd>
        </dl>
        <p class="pp-debug__status" data-pp-debug-status>
          Bloque Liquid renderizado. Esperando que product-timer.js consulte la API.
        </p>
        <p class="pp-debug__hint">
          Usa este bloque para PRODUCT_TIMER, DELIVERY_CUTOFF, LOW_STOCK y FREE_SHIPPING_GOAL cuando la ubicacion sea PRODUCT_PAGE.
        </p>
      </aside>
    {% endif %}
  </div>
  <script id="counterpulse-variants-{{ block.id }}" type="application/json">
    [
      {%- for variant in product.variants -%}
        {
          "id": "gid://shopify/ProductVariant/{{ variant.id }}",
          "legacyId": "{{ variant.id }}",
          "inventoryQuantity": {% if variant.inventory_quantity != blank %}{{ variant.inventory_quantity | json }}{% else %}null{% endif %},
          "available": {{ variant.available | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>
{% elsif block.settings.debugMode %}
  <div
    class="pp-root pp-product-timer pp-root--debug"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-locale="{{ request.locale.iso_code | default: 'en' | escape }}"
    data-country="{{ localization.country.iso_code | default: '' | escape }}"
    data-product-id=""
    data-debug="{{ block.settings.debugMode }}"
    data-debug-block="Promo Pulse product timer"
    {{ block.shopify_attributes }}
  >
    <aside class="pp-debug pp-debug--warning" role="status" aria-live="polite">
      <strong>Promo Pulse product timer renderizado sin producto</strong>
      <p class="pp-debug__status" data-pp-debug-status>
        Shopify no expuso un objeto product en este contexto. Agrega este bloque dentro de un template de producto.
      </p>
    </aside>
  </div>
{% endif %}
<script src="{{ 'discount-code.js' | asset_url }}" defer></script>
<script src="{{ 'delivery-cutoff.js' | asset_url }}" defer></script>
<script src="{{ 'low-stock.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Promo Pulse product timer",
  "target": "section",
  "stylesheet": "promo-pilot.css",
  "javascript": "product-timer.js",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "campaignId",
      "label": "Campaign ID"
    },
    {
      "type": "select",
      "id": "fallbackMode",
      "label": "Campaign selection",
      "default": "AUTO_ELIGIBLE",
      "options": [
        {
          "value": "AUTO_ELIGIBLE",
          "label": "Auto eligible"
        },
        {
          "value": "SPECIFIC_CAMPAIGN",
          "label": "Specific campaign"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "CENTER",
      "options": [
        {
          "value": "LEFT",
          "label": "Left"
        },
        {
          "value": "CENTER",
          "label": "Center"
        },
        {
          "value": "RIGHT",
          "label": "Right"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "compactMode",
      "label": "Compact mode",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "showIcon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "debugMode",
      "label": "Debug mode",
      "default": false
    },
    {
      "type": "text",
      "id": "apiBaseUrl",
      "label": "App backend URL for development",
      "info": "Optional. Use the Shopify CLI tunnel URL if the app proxy returns 404 in development."
    }
  ]
}
{% endschema %}

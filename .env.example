# App identity and runtime.
COMPOSE_PROJECT_NAME=promo-pulse-bars-timers
SHARED_DOCKER_NETWORK=shared_apps
PROMO_PULSE_APP_NAME="Promo Pulse: Bars & Timers"
APP_ENV=development
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=256
PORT=3000
FRONTEND_PORT=8002
HOST=
HMR_PORT=
E2E_HMR_PORT=

# Shopify app configuration.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2026-04
SCOPES=read_products,read_orders,read_discounts,write_discounts,write_pixels,read_customer_events,read_markets,write_markets,read_files,read_themes
SHOPIFY_APP_URL=
PROD_SHOPIFY_APP_URL=
DEV_SHOPIFY_APP_URL=
SHOP_CUSTOM_DOMAIN=
APP_HOST=app-promo-pulse.zuam.dev

# Database.
APP_DB_NAME=promo_pulse
APP_DB_USER=promo_pulse
APP_DB_PASSWORD=replace-with-app-db-password
# Development uses SQLite. Production/Docker should provide a Postgres DATABASE_URL.
DATABASE_URL=file:./dev.sqlite
DEVELOPMENT_DATABASE_URL=file:./dev.sqlite

# Local plan and premium feature overrides.
# Valid plans: FREE, STARTER, GROWTH, PRO.
PROMO_PULSE_DEV_PLAN=PRO
PROMO_PULSE_PLAN_LIMITS_JSON=
PROMO_PULSE_STAGE2_FLAGS_JSON=
PROMO_PULSE_PREMIUM_FEATURE_PLANS_JSON=

# AI campaign builder.
# Provider switch: "mock" (default, no network — deterministic fixtures used in
# dev/tests) or "openai" (real generation). Anything other than "openai", or a
# missing OPENAI_API_KEY, forces the mock provider.
PROMO_PULSE_AI_PROVIDER=mock
# OpenAI secret key. Required only when PROMO_PULSE_AI_PROVIDER=openai.
OPENAI_API_KEY=
# Text model for the standard (no reference image) campaign generation.
OPENAI_MODEL=gpt-5.4-mini
# Multimodal/vision model used when a reference image is uploaded in the AI
# campaign builder, so the AI can analyze the image and reproduce its layout,
# colors, and proportions. Switch to gpt-5.5 or another vision-capable model.
OPENAI_VISION_MODEL=gpt-5.4
# Smaller models for the cheaper auxiliary calls (translations / A-B variants).
OPENAI_TRANSLATION_MODEL=gpt-5.4-nano
OPENAI_VARIANT_MODEL=gpt-5.4-nano
# Chat/responses endpoint used for all text + vision generation calls.
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
# Image-generation model + endpoints for the "generate visual assets" feature
# (PRO + write_files only). IMAGES_URL is text-to-image; IMAGE_EDITS_URL is
# image-to-image, used when an asset region is cropped from the uploaded
# reference image and recreated faithfully from that crop.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGES_URL=https://api.openai.com/v1/images/generations
OPENAI_IMAGE_EDITS_URL=https://api.openai.com/v1/images/edits

# Help and contact email delivery.
# Cloudflare Email Routing receives contact@zuam.dev and forwards it to Gmail.
# Outbound app email should use Resend SMTP from the verified zuam.dev domain,
# not the personal Gmail SMTP account that receives the forwarded messages.
CONTACT_EMAIL=contact@zuam.dev
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=resend
EMAIL_PASS=
EMAIL_FROM=noreply@zuam.dev
EMAIL_FROM_NAME="Promo Pulse"
EMAIL_REPLY_TO=contact@zuam.dev

# Shopify advanced discount function.
SHOPIFY_ADVANCED_DISCOUNT_FUNCTION_HANDLE=promo-pulse-advanced-discounts
SHOPIFY_ADVANCED_DISCOUNT_FUNCTION_ID=
SHOPIFY_ADVANCED_DISCOUNT_METAFIELD_NAMESPACE=
SHOPIFY_ADVANCED_DISCOUNT_METAFIELD_KEY=advanced-discount-config

# Storefront API protection.
STOREFRONT_RATE_LIMIT_WINDOW_MS=60000
STOREFRONT_RATE_LIMIT_MAX_REQUESTS=120
STOREFRONT_RATE_LIMIT_E2E_MAX_REQUESTS=1000
# Optional comma-separated storefront hosts allowed to call direct /api/storefront/*
# endpoints in development when bypassing Shopify App Proxy with apiBaseUrl.
PROMO_PULSE_ALLOWED_STOREFRONT_HOSTS=

# Storefront campaign cache. Memory is always used; file cache is enabled outside tests.
STOREFRONT_FILE_CACHE_ENABLED=true
STOREFRONT_CACHE_DIR=.cache/storefront
STOREFRONT_SNAPSHOT_CACHE_TTL_MS=21600000
STOREFRONT_PAYLOAD_CACHE_TTL_MS=3600000
STOREFRONT_CLIENT_CACHE_TTL_MS=300000
STOREFRONT_IMPRESSION_GATE_CACHE_TTL_MS=60000
STOREFRONT_PAYLOAD_CACHE_MAX_ENTRIES=500

# Local browser test mode. Keep false outside Playwright/Vitest.
E2E_TEST_MODE=false
E2E_BASE_URL=http://localhost:31338
E2E_PORT=31338
E2E_DEMO_SHOP_DOMAIN=demo-shop.myshopify.com
E2E_AUTH_COOKIE=promo_pulse_e2e_shop

# Real Shopify E2E reference. The real-store scripts load .env.real-e2e.
REAL_E2E_ENABLED=false
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_URL=
SHOPIFY_ADMIN_API_VERSION=2026-04
SHOPIFY_STOREFRONT_URL=
PROMO_PULSE_APP_ADMIN_URL=
PROMO_PULSE_SHOPIFY_APP_HANDLE=promo-pulse-bars-timers
REAL_E2E_STORAGE_STATE=playwright/.auth/shopify-admin.json
SHOPIFY_STOREFRONT_PASSWORD=
SHOPIFY_ADMIN_ACCESS_TOKEN=
REAL_E2E_THEME_NAME=
REAL_E2E_PRODUCT_HANDLE=
REAL_E2E_ALLOW_CHECKOUT=false
REAL_E2E_ALLOW_ORDER=false
REAL_E2E_CLEANUP=false
REAL_E2E_HEADLESS=true
REAL_E2E_DEBUG=false
REAL_E2E_LOCAL_THEME_ASSET_FALLBACK=false
REAL_E2E_THEME_ASSETS_DIR=extensions/promo-pulse-theme/assets
PROMOPULSE_REAL_E2E_PLAN=PRO
REAL_E2E_TIMEOUT_MS=90000
REAL_E2E_AUTH_BROWSER=chrome
REAL_E2E_AUTH_PROFILE_DIR=playwright/.auth/shopify-admin-profile
REAL_E2E_CDP_URL=http://127.0.0.1:9222
